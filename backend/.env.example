# Backend environment variables. Copy to `.env` for local dev, OR set these
# in the Render dashboard for production. Do NOT commit `.env` (already in .gitignore).

# === Database ===
# Local dev: mongodb://localhost:27017
# Production: MongoDB Atlas connection string, e.g.
#   mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017
DB_NAME=nearscene

# === CORS ===
# Comma-separated list of allowed origins, OR "*" for any (dev only).
# Production example: https://nearscene.vercel.app,https://www.nearscene.com
CORS_ORIGINS=*

# === Auth ===
# Generate a strong random string for production. `openssl rand -hex 32` works.
JWT_SECRET=change_me_to_a_long_random_string

# === Stripe ===
# Test mode keys start with sk_test_ / pk_test_. Live keys start with sk_live_.
STRIPE_API_KEY=sk_test_replace_me
# Webhook signing secret from Stripe dashboard (whsec_...). Optional in dev.
STRIPE_WEBHOOK_SECRET=

# === Payments ===
# Platform commission (0.05 = 5%) deducted from each ticket purchase.
COMMISSION_RATE=0.05

# === URLs ===
# Used as fallback origin when the request doesn't include one (e.g. webhooks).
# In production, set this to your deployed frontend URL.
PUBLIC_FRONTEND_URL=http://localhost:3000
